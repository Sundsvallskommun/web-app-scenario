generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:../data/database/database.db"
}

model Image {
  id         Int        @id @default(autoincrement())
  name       String
  filename   String
  url        String
  scenarios  Scenario[]
  categories Category[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model Scenario {
  id          Int       @id @default(autoincrement())
  assistantId String
  name        String
  description String?
  published   Boolean   @default(false)
  imageId     Int?
  image       Image?    @relation(fields: [imageId], references: [id])
  categoryId  Int?
  category    Category? @relation(fields: [categoryId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Category {
  id                     Int                    @id @default(autoincrement())
  name                   String                 @unique
  imageId                Int?
  image                  Image?                 @relation(fields: [imageId], references: [id])
  adGroups               CategoryAdGroup[]
  externalUserCategories ExternalUserCategory[]
  scenarios              Scenario[]
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
}

model CategoryAdGroup {
  id         Int      @id @default(autoincrement())
  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  value      String
  sortOrder  Int

  @@unique([categoryId, sortOrder])
}

model ScenarioIntroText {
  id        Int      @id @default(autoincrement())
  text      String
  sortOrder Int      @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExternalUser {
  id           Int                    @id @default(autoincrement())
  name         String
  org          String?
  personNumber String
  categories   ExternalUserCategory[]
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
}

model ExternalUserCategory {
  externalUserId Int
  categoryId     Int
  externalUser   ExternalUser @relation(fields: [externalUserId], references: [id], onDelete: Cascade)
  category       Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([externalUserId, categoryId])
}
